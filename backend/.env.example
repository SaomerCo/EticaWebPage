# Puerto donde corre el servidor Express
PORT=4000
NODE_ENV=development

# Conexión a PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paes_mentor
DB_USER=postgres
DB_PASSWORD=postgres

# Ollama (IA local). No requiere usuario/contraseña: corre en tu propio
# computador. Si usaste un modelo distinto a llama3.2, cámbialo aquí.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
